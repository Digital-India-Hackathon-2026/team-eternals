# SmartHealthAI — Backend Environment Configuration
# Copy this file to .env and fill in the values

# Database URL for Prisma migrations and setups (IPv4 compatible pooler URL)
# Example: DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
DATABASE_URL=

# Supabase Credentials (obtain from Settings -> API in Supabase dashboard)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# OpenRouter AI credentials for Clinical Care Guidance Symptom Chat
OPENROUTER_API_KEY=

# Deployed Frontend Vercel URL (used to configure secure CORS)
# Example: FRONTEND_URL=https://smarthealthai.vercel.app
FRONTEND_URL=

# Server Port (Render will populate this automatically in production)
PORT=5001
